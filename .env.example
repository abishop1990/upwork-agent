# Copy this to .env and fill in your actual values
# NEVER commit .env to git

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Upwork (sensitive - store in .env, not config.json)
UPWORK_EMAIL=your-email@example.com
UPWORK_PASSWORD=your-password-here

# Discord (webhook URL for notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-here

# Optional: Encryption key for storing credentials
# ENCRYPTION_KEY=your-encryption-key-here
